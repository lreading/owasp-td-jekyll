---
layout: null
---
[
  {%- assign search_pages = site.html_pages | where_exp: "page", "page.title and page.search != false" | sort: "title" -%}
  {%- for search_page in search_pages -%}
    {
      "title": {{ search_page.title | downcase | jsonify }},
      "title_display": {{ search_page.title | jsonify }},
      "group": {{ search_page.group | default: "" | downcase | jsonify }},
      "group_display": {{ search_page.group | default: "" | jsonify }},
      "url": {{ search_page.url | relative_url | jsonify }},
      "content_html": {{ search_page.content | markdownify | jsonify }},
      "content": {{ search_page.content | markdownify | strip_html | normalize_whitespace | downcase | jsonify }},
      "content_display": {{ search_page.content | markdownify | strip_html | normalize_whitespace | jsonify }}
    }{%- unless forloop.last -%},{%- endunless -%}
  {%- endfor -%}
]
